DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.your-domain.com

APP_VERSION=1.0.0
APP_BUILD=pilot

DB_NAME=edutech_prod
DB_USER=edutech_user
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://app.your-domain.com
CSRF_TRUSTED_ORIGINS=https://app.your-domain.com,https://api.your-domain.com

ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

THROTTLE_LOGIN=10/minute
THROTTLE_ATTEMPT_SAVE=120/minute
THROTTLE_BULK_IMPORT=10/hour
